{
"manifest_version": 3,
"name": "De-Rad",
"version": "1.0",
 "description": "plugin designed to block political content",
 "permissions": ["storage"],
 "host_permissions": ["<all_urls>"],
 "action": {
    "default_popup":"popup.html",
    "default_icon": "icons/icon.png"
 },
 "content_scripts":[{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "run_at": "document_idle"
 }]
}
 
